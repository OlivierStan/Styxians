# ====================================================================
# UNREAL ENGINE - SUBFOLDER (Game/) PROJECTS
# ====================================================================
# Ignore built/temporary directories inside the Game folder
Game/Binaries/
Game/Build/
Game/DerivedDataCache/
Game/Intermediate/
Game/Saved/

# Ignore nested plugin binaries and intermediate steps
Game/Plugins/**/Binaries/
Game/Plugins/**/Intermediate/

# Built data files for maps (Unreal generates these locally)
Game/*_BuiltData.uasset

# Don't track source art directory raw backups
Game/SourceArt/

# ====================================================================
# IDE & COMPILATION FILES
# ====================================================================
