### UnrealEngine ###
# Visual Studio 2015 user specific files
Game/.vs/

# Compiled Object files
*.slo
*.lo
*.o
*.obj

# Precompiled Headers
*.gch
*.pch

# Compiled Dynamic libraries
*.so
*.dylib
*.dll

# Fortran module files
*.mod

# Compiled Static libraries
*.lai
*.la
*.a
*.lib

# Executables
*.exe
*.out
*.app
*.ipa

# These project files can be generated by the engine
Game/*.xcodeproj
Game/*.xcworkspace
Game/*.sln
Game/*.suo
Game/*.opensdf
Game/*.sdf
Game/*.VC.db
Game/*.VC.opendb

# Precompiled Assets
Game/SourceArt/**/*.png
Game/SourceArt/**/*.tga

# Binary Files
Game/Binaries/*
Game/Plugins/*/Binaries/*

# Builds
Game/Build/*

# Whitelist PakBlacklist-<BuildConfiguration>.txt files
!Game/Build/*/
Game/Build/*/**
!Game/Build/*/PakBlacklist*.txt

# Don't ignore icon files in Build
!Game/Build/**/*.ico

# Built data for maps
*_BuiltData.uasset

# Configuration files generated by the Editor
Game/Saved/*

# Compiled source files for the engine to use
Game/Intermediate/*
Game/Plugins/*/Intermediate/*

# Cache files for the editor to use
Game/DerivedDataCache/*

### UnrealEngine Patch ###
# Don't ignore icon and splash images for mobile app
!Game/Build/IOS/Resources/
Game/Build/IOS/Resources/*
!Game/Build/IOS/Resources/Graphics/
Game/Build/IOS/Resources/Graphics/*
!Game/Build/IOS/Resources/Graphics/*.png
!Game/Build/Android/res/
Game/Build/Android/res/*
!Game/Build/Android/res/*/
Game/Build/Android/res/*/*
!Game/Build/Android/res/*/*.png
# Ignore plugins binaries on deep subfolders
Game/Plugins/**/Binaries/*
Game/Plugins/**/Intermediate/*

